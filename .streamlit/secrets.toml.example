# ─── Canva Connect API Credentials ───
# Get these from: https://www.canva.com/developers
#
# 1. Log in to Canva Developer Portal
# 2. Click "Create an integration"
# 3. Set the scopes: asset:write, asset:read
# 4. Set the redirect URL to your app URL (e.g. https://yourapp.streamlit.app/)
# 5. Copy Client ID and generate a Client Secret
# 6. Replace the values below

CANVA_CLIENT_ID = "your_canva_client_id_here"
CANVA_CLIENT_SECRET = "your_canva_client_secret_here"

# For local development:
# CANVA_REDIRECT_URI = "http://127.0.0.1:8501/"
# For Streamlit Cloud (use your actual app URL):
# CANVA_REDIRECT_URI = "https://yourapp.streamlit.app/"
